{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "node16",
        "moduleResolution": "node16",
        "target": "ES2022",
        "lib": ["ES2022"],
        "outDir": "../../dist/api",
        "rootDir": ".",
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "noUnusedParameters": false,
        "types": ["node"]
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["node_modules", "dist"]
}
