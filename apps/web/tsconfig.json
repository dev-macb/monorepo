{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "jsx": "react-jsx",
        "outDir": "../../dist/app",
        "rootDir": ".",
        "allowImportingTsExtensions": true,
        "types": ["vite/client", "jest", "@testing-library/jest-dom"],
        "noEmit": true
    },
    "include": ["src/**/*", "tests/**/*"],
    "exclude": ["node_modules", "dist"]
}
